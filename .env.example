NODE_ENV=development
PORT=5000

# MongoDB Connection String (Replace with your own MongoDB Atlas or Local URI)
MONGODB_URI=mongodb://localhost:27017/your_database_name

# JWT Config (Generate secure random keys)
# Generate command: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_at_least_64_characters
JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_different_from_above
JWT_REFRESH_EXPIRES_IN=7d

# CORS Allowed Origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,http://127.0.0.1:5000

# Security Rate Limiting settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Security Account Lockout config
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15
